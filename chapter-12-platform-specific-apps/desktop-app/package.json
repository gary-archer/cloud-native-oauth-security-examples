{
    "name": "demo-desktop-app",
    "version": "1.0.0",
    "description": "A desktop app that uses native logins with a loopback redirect URI",
    "author": "Curity AB",
    "license": "Apache-2.0",
    "main": "main.bundle.js",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "start": "npm run webpackMain && npm run webpackRenderer && npx electron ./dist",
        "webpackMain": "NODE_OPTIONS='--import tsx' webpack --config webpack/main.ts",
        "webpackRenderer": "NODE_OPTIONS='--import tsx' webpack --config webpack/renderer.ts"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "get-port": "^7.1.0",
        "jose": "^6.1.3",
        "open": "^10.1.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@types/node": "^22.15.18",
        "@types/react": "^19.2.4",
        "@types/react-dom": "^19.2.3",
        "copy-webpack-plugin": "^14.0.0",
        "electron": "^40.4.1",
        "ts-loader": "^9.5.2",
        "tsx": "^4.20.3",
        "typescript": "5.9.2",
        "webpack": "^5.105.4",
        "webpack-cli": "^6.0.1"
    }
}
